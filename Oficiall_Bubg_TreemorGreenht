<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>PUBG CARRY | Официальный сервис сопровождения</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #0a0c15;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .parallax-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: radial-gradient(ellipse at 30% 40%, #1a2a3a, #03060b);
        }

        .parallax-bg::before {
            content: "";
            position: absolute;
            width: 200%;
            height: 200%;
            top: -50%;
            left: -50%;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800" opacity="0.15"><path fill="none" stroke="%23ffaa33" stroke-width="1.5" d="M0,400 L300,200 L600,450 L900,150 L1200,350" /><circle cx="200" cy="300" r="3" fill="%23ffaa33"/><circle cx="550" cy="150" r="4" fill="%23ffaa33"/><circle cx="850" cy="500" r="3" fill="%23ffaa33"/><circle cx="1000" cy="250" r="2" fill="%23ffaa33"/></svg>') repeat;
            animation: slowMove 40s linear infinite;
            pointer-events: none;
        }

        @keyframes slowMove {
            0% { transform: translate(0,0) rotate(0deg);}
            100% { transform: translate(10%,10%) rotate(5deg);}
        }

        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }
        .particle {
            position: absolute;
            background: rgba(255, 180, 50, 0.4);
            border-radius: 50%;
            filter: blur(2px);
            animation: floatParticle 8s infinite alternate;
        }
        @keyframes floatParticle {
            0% { transform: translateY(0px) translateX(0px); opacity: 0.2; }
            100% { transform: translateY(-40px) translateX(20px); opacity: 0.8; }
        }

        .site-wrapper {
            max-width: 1300px;
            margin: 0 auto;
            padding: 30px 24px 60px;
            position: relative;
            z-index: 5;
        }

        .premium-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 60px;
            padding: 15px 25px;
            background: rgba(10, 15, 25, 0.65);
            backdrop-filter: blur(16px);
            border-radius: 100px;
            border: 1px solid rgba(255, 170, 50, 0.3);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-icon {
            font-size: 2.5rem;
            filter: drop-shadow(0 0 8px #ffaa33);
        }

        .logo-text h1 {
            font-family: 'Orbitron', monospace;
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FFD966, #FF9F2E, #FF6600);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 2px;
        }

        .logo-text p {
            color: #b9c7dd;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
        }

        .admin-trigger {
            background: linear-gradient(95deg, #2a2e3f, #1a1e2c);
            border: 1px solid #ffaa55;
            color: #ffcc77;
            font-weight: bold;
            padding: 10px 28px;
            border-radius: 60px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.25s;
            font-family: 'Orbitron', monospace;
        }

        .admin-trigger:hover {
            background: #ffaa33;
            color: #0a0f1e;
            transform: scale(1.02);
        }

        .order-card {
            background: rgba(8, 14, 22, 0.75);
            backdrop-filter: blur(20px);
            border-radius: 56px;
            border: 1px solid rgba(255, 170, 60, 0.5);
            box-shadow: 0 30px 50px rgba(0,0,0,0.5);
            padding: 40px 35px;
            max-width: 650px;
            margin: 0 auto 50px;
        }

        .glow-title {
            text-align: center;
            font-family: 'Orbitron', monospace;
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(120deg, #FFF0C0, #FFB347);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 10px;
        }

        .subtitle {
            text-align: center;
            color: #aab3cc;
            margin-bottom: 32px;
            display: block;
        }

        .input-group-modern {
            margin-bottom: 28px;
        }

        .input-group-modern label {
            display: block;
            color: #ffdd99;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 0.85rem;
            text-transform: uppercase;
        }

        .custom-select, .custom-input {
            width: 100%;
            background: #0f1820;
            border: 1.5px solid #2e3e48;
            border-radius: 60px;
            padding: 16px 24px;
            font-size: 1rem;
            color: #f5f9ff;
            transition: all 0.2s;
        }

        .custom-select:focus, .custom-input:focus {
            border-color: #ffaa44;
            outline: none;
            box-shadow: 0 0 0 3px rgba(255,170,68,0.3);
        }

        .messenger-premium {
            display: flex;
            gap: 20px;
            margin-top: 10px;
        }

        .msg-premium {
            flex: 1;
            background: #101a22;
            border: 2px solid #2c4050;
            border-radius: 60px;
            padding: 14px 0;
            text-align: center;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            color: #ccdeee;
        }

        .msg-premium.selected {
            background: linear-gradient(105deg, #ffaa33, #ff8800);
            border-color: #ffffff;
            color: #0f1a1f;
            box-shadow: 0 0 18px #ffaa55;
        }

        .order-button {
            width: 100%;
            background: linear-gradient(95deg, #ffaa33, #f57c00);
            border: none;
            padding: 18px;
            border-radius: 60px;
            font-weight: 800;
            font-size: 1.5rem;
            font-family: 'Orbitron', monospace;
            color: #111;
            margin-top: 15px;
            cursor: pointer;
            box-shadow: 0 10px 0 #a04500;
        }

        .order-button:active {
            transform: translateY(4px);
            box-shadow: 0 5px 0 #a04500;
        }

        .admin-overlay-premium {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            visibility: hidden;
            opacity: 0;
            transition: 0.25s;
        }

        .admin-overlay-premium.active {
            visibility: visible;
            opacity: 1;
        }

        .admin-card {
            background: #0e141f;
            width: 92%;
            max-width: 550px;
            border-radius: 48px;
            border: 1px solid #ffbb55;
            padding: 20px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #ffaa44;
            padding-bottom: 12px;
            margin-bottom: 20px;
        }

        .client-list-scroll {
            max-height: 380px;
            overflow-y: auto;
            padding-right: 6px;
        }

        .client-card-premium {
            background: #0c141d;
            border-left: 5px solid #ffaa33;
            margin-bottom: 16px;
            padding: 15px;
            border-radius: 28px;
        }

        .accept-order-btn {
            background: #ffaa33;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: bold;
            margin-top: 12px;
            cursor: pointer;
        }

        .close-admin-btn {
            background: #2c3e44;
            color: white;
            border: none;
            padding: 6px 20px;
            border-radius: 60px;
            cursor: pointer;
        }

        @media (max-width: 600px) {
            .order-card { padding: 28px 18px; }
            .glow-title { font-size: 1.6rem; }
            .premium-header { border-radius: 40px; padding: 12px 20px; }
            .msg-premium { font-size: 0.9rem; gap: 6px; }
        }
    </style>
</head>
<body>
<div class="parallax-bg"></div>
<div class="particles" id="particlesContainer"></div>

<div class="site-wrapper">
    <div class="premium-header">
        <div class="logo-area">
            <div class="logo-icon">🏆</div>
            <div class="logo-text">
                <h1>PUBG CARRY</h1>
                <p>OFFICIAL BOOSTING SERVICE</p>
            </div>
        </div>
        <button class="admin-trigger" id="adminOpenBtnPremium">👑 АДМИН ПАНЕЛЬ</button>
    </div>

    <div class="order-card">
        <div class="glow-title">ЗАКАЗАТЬ СУПРОВОД</div>
        <div style="text-align: center; margin-bottom: 25px;">
            <span class="subtitle">Элитный бустинг / Помощь в игре</span>
        </div>

        <div class="input-group-modern">
            <label>🌍 ВАША СТРАНА</label>
            <select id="countrySelectPremium" class="custom-select">
                <option value="Россия" data-code="+7" selected>🇷🇺 Россия (+7)</option>
                <option value="Украина" data-code="+380">🇺🇦 Украина (+380)</option>
                <option value="Польша" data-code="+48">🇵🇱 Польша (+48)</option>
                <option value="Турция" data-code="+90">🇹🇷 Турция (+90)</option>
                <option value="США" data-code="+1">🇺🇸 США (+1)</option>
                <option value="Великобритания" data-code="+44">🇬🇧 Великобритания (+44)</option>
            </select>
        </div>

        <div class="input-group-modern">
            <label>📱 НОМЕР ТЕЛЕФОНА (ПОЛНЫЙ)</label>
            <input type="tel" id="phoneNumberPremium" class="custom-input" placeholder="+7 XXX XXX XX XX" autocomplete="off">
        </div>

        <div class="input-group-modern">
            <label>💬 МЕССЕНДЖЕР ДЛЯ СВЯЗИ</label>
            <div class="messenger-premium" id="messengerGroupPremium">
                <div class="msg-premium" data-msg="Viber">📞 VIBER</div>
                <div class="msg-premium" data-msg="Telegram">✈️ TELEGRAM</div>
            </div>
        </div>

        <button class="order-button" id="orderBtnPremium">🎮 ЗАКАЗАТЬ СЕЙЧАС</button>
    </div>
</div>

<div id="adminModalPremium" class="admin-overlay-premium">
    <div class="admin-card">
        <div class="admin-header">
            <h3 style="color:#ffcc77;">👑 АДМИН | КЛИЕНТЫ</h3>
            <button class="close-admin-btn" id="closeAdminPremiumBtn">✖ Закрыть</button>
        </div>
        <div id="adminOrdersList" class="client-list-scroll">
            <div style="color:#99aac0; text-align:center; padding:20px;">Нет заказов</div>
        </div>
    </div>
</div>

<script>
    let ordersArray = JSON.parse(localStorage.getItem('pubg_orders')) || [];
    let selectedMessengerPremium = null;

    const countrySelect = document.getElementById('countrySelectPremium');
    const phoneInput = document.getElementById('phoneNumberPremium');
    const messengerOptions = document.querySelectorAll('.msg-premium');
    const orderButton = document.getElementById('orderBtnPremium');
    const adminOpenBtn = document.getElementById('adminOpenBtnPremium');
    const adminModal = document.getElementById('adminModalPremium');
    const closeAdminBtn = document.getElementById('closeAdminPremiumBtn');
    const adminOrdersContainer = document.getElementById('adminOrdersList');

    const prefixMap = {
        "Россия": "+7",
        "Украина": "+380",
        "Польша": "+48",
        "Турция": "+90",
        "США": "+1",
        "Великобритания": "+44"
    };

    function updatePhoneByCountry() {
        const selectedCountry = countrySelect.value;
        const newPrefix = prefixMap[selectedCountry];
        let currentPhone = phoneInput.value.trim();
        if (currentPhone === "") {
            phoneInput.value = newPrefix;
        } else if (!currentPhone.startsWith(newPrefix)) {
            let withoutOldCode = currentPhone.replace(/^\+[0-9]{1,4}\s*/, '');
            phoneInput.value = newPrefix + withoutOldCode;
        }
    }

    countrySelect.addEventListener('change', updatePhoneByCountry);

    function getFullNumber() {
        return phoneInput.value.trim();
    }

    messengerOptions.forEach(opt => {
        opt.addEventListener('click', () => {
            messengerOptions.forEach(o => o.classList.remove('selected'));
            opt.classList.add('selected');
            selectedMessengerPremium = opt.getAttribute('data-msg');
        });
    });

    function showToastMessage(text, isError = false) {
        const toast = document.createElement('div');
        toast.innerText = text;
        toast.style.position = 'fixed';
        toast.style.bottom = '25px';
        toast.style.left = '50%';
        toast.style.transform = 'translateX(-50%)';
        toast.style.backgroundColor = isError ? '#9e2e2e' : '#1f5f3a';
        toast.style.color = '#ffecb3';
        toast.style.padding = '12px 28px';
        toast.style.borderRadius = '60px';
        toast.style.fontWeight = 'bold';
        toast.style.zIndex = '9999';
        toast.style.backdropFilter = 'blur(10px)';
        toast.style.border = '1px solid #ffaa55';
        toast.style.fontFamily = 'monospace';
        toast.style.boxShadow = '0 5px 20px black';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2800);
    }

    function copyToClip(text) {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text).catch(() => fallbackCopy(text));
        } else {
            fallbackCopy(text);
        }
        showToastMessage(`✅ Номер ${text} скопирован!`, false);
    }
    
    function fallbackCopy(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
    }

    function renderAdminPanel() {
        if (!adminModal.classList.contains('active')) return;
        if (ordersArray.length === 0) {
            adminOrdersContainer.innerHTML = `<div style="color:#aaa; text-align:center; padding:30px;">📭 Заказов пока нет</div>`;
            return;
        }
        let html = '';
        [...ordersArray].reverse().forEach((order) => {
            html += `
                <div class="client-card-premium">
                    <p>🌍 <strong>Страна:</strong> ${escapeHtml(order.country)}</p>
                    <p>📞 <strong>Номер:</strong> ${escapeHtml(order.phone)}</p>
                    <p>💬 <strong>Мессенджер:</strong> ${escapeHtml(order.messenger)}</p>
                    <p>🕒 <strong>Время:</strong> ${order.timestamp}</p>
                    <button class="accept-order-btn" data-copy="${escapeHtml(order.phone)}">✅ Принять заказ (копировать номер)</button>
                </div>
            `;
        });
        adminOrdersContainer.innerHTML = html;
        document.querySelectorAll('.accept-order-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const phoneVal = btn.getAttribute('data-copy');
                if (phoneVal) copyToClip(phoneVal);
                else showToastMessage("Ошибка номера", true);
            });
        });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if(m === '&') return '&amp;';
            if(m === '<') return '&lt;';
            if(m === '>') return '&gt;';
            return m;
        });
    }

    // --- ФУНКЦІЯ ВІДПРАВКИ В ТЕЛЕГРАМ (ТВОЯ БАЗА) ---
    async function sendOrderToTelegram(country, phone, messenger) {
        // УВАГА: ВСТАВ СЮДИ СВОЇ ДАНІ
        const token = "8645814100:AAGW0Qx1LskTVpZwVwI3RXV7ZOKn_Xf2efg"; 
        const chatId = "8453332897"; 
        
        const text = `🏆 НОВЫЙ ЗАКАЗ!\n🌍 Страна: ${country}\n📞 Номер: ${phone}\n💬 Связь: ${messenger}`;
        
        try {
            await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ chat_id: chatId, text: text })
            });
        } catch (error) {
            console.error("Ошибка отправки в Telegram:", error);
        }
    }

    function createOrder(country, phone, messenger) {
        if (!phone.trim()) {
            showToastMessage("❌ Введите номер телефона!", true);
            return false;
        }
        const digits = phone.replace(/[^0-9+]/g, '');
        if (digits.length < 6) {
            showToastMessage("⚠️ Слишком короткий номер! Введите полный номер.", true);
            return false;
        }
        if (!messenger) {
            showToastMessage("⚠️ Выберите мессенджер!", true);
            return false;
        }
        const now = new Date();
        const timestamp = `${now.toLocaleDateString()} ${now.toLocaleTimeString()}`;
        
        // ВІДПРАВКА В БАЗУ
        sendOrderToTelegram(country, phone, messenger);

        ordersArray.push({
            id: Date.now(),
            country: country,
            phone: phone,
            messenger: messenger,
            timestamp: timestamp
        });

        localStorage.setItem('pubg_orders', JSON.stringify(ordersArray));

        showToastMessage(`✅ Заказ оформлен! ${messenger} — свяжемся с вами`, false);
        phoneInput.value = countrySelect.options[countrySelect.selectedIndex].getAttribute('data-code');
        messengerOptions.forEach(o => o.classList.remove('selected'));
        selectedMessengerPremium = null;
        if (adminModal.classList.contains('active')) renderAdminPanel();
        return true;
    }

    orderButton.addEventListener('click', () => {
        const country = countrySelect.value;
        const fullPhone = getFullNumber();
        const messenger = selectedMessengerPremium;
        createOrder(country, fullPhone, messenger);
    });

    function openAdmin() {
        const password = prompt("Введите пароль администратора:");
        if (password === "ZDFX-(89)(77888877)") {
            adminModal.classList.add('active');
            renderAdminPanel();
        } else if (password !== null) {
            showToastMessage("❌ Неверный пароль!", true);
        }
    }

    function closeAdmin() {
        adminModal.classList.remove('active');
    }

    adminOpenBtn.addEventListener('click', openAdmin);
    closeAdminBtn.addEventListener('click', closeAdmin);
    adminModal.addEventListener('click', (e) => {
        if (e.target === adminModal) closeAdmin();
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && adminModal.classList.contains('active')) closeAdmin();
    });

    function createParticles() {
        const container = document.getElementById('particlesContainer');
        for (let i = 0; i < 60; i++) {
            const particle = document.createElement('div');
            particle.classList.add('particle');
            const size = Math.random() * 6 + 2;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.animationDuration = 7 + Math.random() * 15 + 's';
            particle.style.animationDelay = Math.random() * 10 + 's';
            particle.style.background = `rgba(255, 180, ${50 + Math.random() * 80}, ${0.2 + Math.random() * 0.4})`;
            container.appendChild(particle);
        }
    }
    createParticles();
    phoneInput.value = "+7";
</script>
</body>
</html>
